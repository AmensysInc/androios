{
  "expo": {
    "name": "Zeno Time Flow",
    "slug": "zenotimeflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "zenotimeflow",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zenotimeflow.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock Zeno Time Flow and confirm clock in or clock out with Face ID."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zenotimeflow.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zeno Time Flow to choose a photo for face enrollment.",
          "cameraPermission": "Allow Zeno Time Flow to take a photo for face enrollment and verification."
        }
      ]
    ]
  }
}
