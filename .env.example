# Copy to `.env` and adjust if your backend is not on localhost:8000.
# Used for native (iOS/Android). Expo Web ignores this and always uses same-origin /api → Metro → Django
# so the browser avoids CORS. On Android emulator use http://10.0.2.2:8000 if 127.0.0.1 fails.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
